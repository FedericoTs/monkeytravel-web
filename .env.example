# Supabase Configuration
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PostHog Configuration (Analytics, Feature Flags, A/B Testing)
# Get these from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# PostHog Server-Side (optional, for API routes and middleware)
# Use the same key or a project API key with higher permissions
POSTHOG_API_KEY=phc_xxxxxxxxxxxxx

# PostHog Query API — used by the marketing "top posts" digest to rank blog
# posts by pageviews (lib/blog/popularity.ts). Optional: if unset, the digest
# falls back to newest-first. The PERSONAL key (phx_…, NOT the phc_ project
# key) is created at PostHog → Settings → Personal API Keys with "Query Read"
# scope. PROJECT_ID is the numeric id in the project settings/URL.
POSTHOG_PERSONAL_API_KEY=phx_xxxxxxxxxxxxx
POSTHOG_PROJECT_ID=12345

# Email Service (Resend) — see docs/EMAIL_HANDOFF.md for full setup
# The code self-skips gracefully when RESEND_API_KEY is unset — invites
# and notifications still work in-app, they just don't dispatch email.
# Get the key from https://resend.com/api-keys after verifying your
# sending domain (DNS records: SPF + DKIM + DMARC).
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM="MonkeyTravel <noreply@monkeytravel.app>"
EMAIL_REPLY_TO=hello@monkeytravel.app
# Optional (future): HMAC secret for one-click unsubscribe tokens
EMAIL_UNSUBSCRIBE_SECRET=set-a-random-32-byte-hex-string

# Supabase "Send Email" auth hook secret.
# Generated in Supabase Dashboard → Authentication → Hooks → Send Email
# when you point the hook at /api/auth/send-email. Paste the full value
# (it looks like "v1,whsec_..."). The route fails closed without it.
SEND_EMAIL_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxx
