{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "app/api/ai/generate/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/ai/regenerate-activity/route.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/ai/generate-more-days/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "app/api/hotels/*/route.ts": {
      "maxDuration": 15,
      "memory": 256
    },
    "app/api/places/*/route.ts": {
      "maxDuration": 15,
      "memory": 256
    },
    "app/api/travel/*/route.ts": {
      "maxDuration": 15,
      "memory": 256
    },
    "app/api/trips/*/route.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "app/api/admin/*/route.ts": {
      "maxDuration": 30,
      "memory": 256
    },
    "app/api/cron/*/route.ts": {
      "maxDuration": 60,
      "memory": 256
    }
  },
  "regions": ["iad1"],
  "crons": [
    {
      "//": "Daily — recompute /explore Editor's Picks (age>=7d, fork_count>=5, trending_score>=50). Authenticated via CRON_SECRET env.",
      "path": "/api/cron/recompute-editors-picks",
      "schedule": "17 5 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.monkeytravel.app"
        }
      ],
      "destination": "https://monkeytravel.app/:path",
      "permanent": true
    }
  ]
}
