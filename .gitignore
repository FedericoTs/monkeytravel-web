# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example

# direnv — per-project SUPABASE_ACCESS_TOKEN / VERCEL_TOKEN. The
# committed template is .envrc.example; .envrc holds real secrets.
.envrc

# whatsapp bridge databases
/store/

# supabase
supabase/.temp/

# Capacitor native platforms — generated by `npx cap add ios|android`.
# These are large, regenerate cleanly, and don't belong in the web repo.
# If you want them tracked, put them in a separate monkeytravel-mobile repo
# and remove these two lines.
/ios/
/android/

# Capacitor build outputs
.capacitor/

# remotion video output
video/output/
public/video/screens/

# cross-publish automation (cookies, state files)
.flipboard-cookies.json
.flipboard-state.json
.medium-cookies.json
.medium-state.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Claude Code local session state — process-id locks etc., not the
# project's own .claude/skills/ docs which DO belong in the repo.
.claude/scheduled_tasks.lock
.claude/settings.local.json
test-results/
playwright-report/
.audit/raw-data.json
